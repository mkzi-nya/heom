#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
1.py —— 码表前缀／通配查询工具
调用：python 1.py <pattern>
pattern 可以是：
    • 纯字母前缀，如 abcd
    • 以 * 或 ** 结尾，如 abc*   ab**
"""
import sys
from collections import defaultdict
from pathlib import Path

TABLE_FILE = Path(__file__).resolve()parent.with_name("heom.txt")      # ./1.txt
ENCODING = "utf-8"

# ------------------------------------------------------------
# 加载码表：code → [chars]
code2chars: dict[str, list[str]] = defaultdict(list)
with TABLE_FILE.open(encoding=ENCODING) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            char, code = line.split()
        except ValueError:
            continue
        code2chars[code].append(char)

# ------------------------------------------------------------
def format_chars(chars: list[str]) -> str:
    """返回 [你,哦,二,] —— 末尾保留逗号（与上一版一致）。"""
    return "[" + ",".join(chars) + "," + "]"

def format_pairs(dic: dict[str, list[str]]) -> str:
    """返回 [(字,编码), …]"""
    pairs = (f"({ch},{cd})" for cd, lst in dic.items() for ch in lst)
    return "[" + ",".join(pairs) + "]"

def exact_codes(prefix: str) -> dict[str, list[str]]:
    return {prefix: code2chars[prefix]} if prefix in code2chars else {}

def wildcard_codes(prefix: str, star_len: int) -> dict[str, list[str]]:
    targ_len = len(prefix) + star_len
    return {c: v for c, v in code2chars.items()
            if len(c) == targ_len and c.startswith(prefix)}

# ------------------------------------------------------------
def output_exact_and_one_star(prefix: str) -> None:
    """正常模式：各级精确 + 一星聚合（含编码列表与计数）"""
    # 1. 前缀精确
    for i in range(1, len(prefix) + 1):
        p = prefix[:i]
        for code, chars in exact_codes(p).items():
            print(f"{code}{format_chars(chars)}")

    # 2. 一星通配
    one_star_dict = wildcard_codes(prefix, 1)
    if one_star_dict:
        total = sum(len(v) for v in one_star_dict.values())
        print(f"{prefix}*:{total} {format_pairs(one_star_dict)}")

def output_two_star_statistics(prefix: str) -> None:
    two_star_dict = wildcard_codes(prefix, 2)
    if not two_star_dict:
        return

    total_chars = sum(len(v) for v in two_star_dict.values())
    print(f"{prefix}**, {total_chars}")

    # 以 prefix + 第三位字母 + '*' 分组
    group: defaultdict[str, list[str]] = defaultdict(list)
    for code in two_star_dict:
        key = f"{code[:len(prefix)+1]}*"          # 如  rr*
        group[key].append(code)

    for key in sorted(group):
        codes = group[key]

        # 如果该组只有一个完整编码，仍按上一版规则直接输出字符列表
        if len(codes) == 1:
            code = codes[0]
            print(f"  {key}{format_chars(code2chars[code])}")
            continue

        # 组内 ≥ 2 个完整编码：统计并替换“1”为字符
        group_total = sum(len(code2chars[c]) for c in codes)
        pair_parts = []
        for c in codes:
            chars = code2chars[c]
            if len(chars) == 1:
                pair_parts.append(f"({c},{chars[0]})")     # 用唯一字符替换数字 1
            else:
                pair_parts.append(f"({c},{len(chars)})")   # 仍用数量
        pairs = ",".join(pair_parts)
        print(f"  {key}:{group_total}  [{pairs}]")

# ------------------------------------------------------------
def handle_star_mode(base: str, star_cnt: int) -> None:
    if star_cnt == 1:
        dic = wildcard_codes(base, 1)
        if dic:
            total = sum(len(v) for v in dic.values())
            print(f"{base}*:{total} {format_pairs(dic)}")
    elif star_cnt == 2:
        output_two_star_statistics(base)
    else:
        print("仅支持末尾最多两个连续 *")
        sys.exit(1)

# ------------------------------------------------------------
def main() -> None:
    if len(sys.argv) != 2:
        print("用法: python 1.py <pattern>")
        sys.exit(1)

    pattern = sys.argv[1].lower()
    if not pattern.isalpha() and not pattern.rstrip("*").isalpha():
        print("pattern 只能包含 a-z 或以 * 结尾")
        sys.exit(1)

    star_part = pattern.lstrip("abcdefghijklmnopqrstuvwxyz")
    base_prefix = pattern[:len(pattern) - len(star_part)]
    star_count = len(star_part)

    if star_count == 0:
        output_exact_and_one_star(base_prefix)
        output_two_star_statistics(base_prefix)
    else:
        handle_star_mode(base_prefix, star_count)

if __name__ == "__main__":
    main()
